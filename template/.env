# ======================== STATIC ========================
# Port the server listens on
PORT=10000

# Enforce wss:// (TLS) connections only
REQUIRE_TLS=true

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8080,https://yourdomain.com

# Unique identifier for this instance
INSTANCE_ID=your-instance-id

# Timezone for timestamps
TIMEZONE=Asia/Ho_Chi_Minh

# Log file path
LOG_FILE_PATH=./logs/app.log

# Max log file size before rotation (MB)
MAX_LOG_SIZE_MB=50

# ======================== DYNAMIC ========================
# Public server status page
STATUS_URL=https://example.com/status

# Client download link
DOWNLOAD_URL=https://example.com/download

# Instance homepage
HOMEPAGE_URL=https://example.com/

# Max simultaneous connections per IP
MAX_CONNECTIONS_PER_IP=2

# Min delay between connections from the same IP
CONNECTION_COOLDOWN=5s

# Min delay between messages (anti-spam)
MESSAGE_COOLDOWN=200ms

# Max characters per message
MAX_MESSAGE_LENGTH=5000

# Max lines per message
MAX_MESSAGE_LINE=50

# Max display name length
MAX_USERNAME_LENGTH=12

# Max tripcode length
MAX_TRIPCODE_LENGTH=64

# Max chat history size in bytes (10 MB)
MAX_HISTORY_BYTES=10485760

# Max messages sent to a newly joined client
MAX_HISTORY_SEND=500
